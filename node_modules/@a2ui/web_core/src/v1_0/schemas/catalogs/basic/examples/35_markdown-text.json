{
    "name": "Markdown Text Support",
    "description": "Demonstrates Markdown rendering in Text component.",
    "messages": [
        {
            "version": "v1.0",
            "createSurface": {
                "surfaceId": "gallery-markdown-text",
                "catalogId": "https://a2ui.org/specification/v1_0/catalogs/basic/catalog.json",
                "sendDataModel": true
            }
        },
        {
            "version": "v1.0",
            "updateComponents": {
                "surfaceId": "gallery-markdown-text",
                "components": [
                    {
                        "id": "root",
                        "component": "Card",
                        "child": "main_column"
                    },
                    {
                        "id": "main_column",
                        "component": "Column",
                        "children": ["title_text", "markdown_content"],
                        "align": "stretch"
                    },
                    {
                        "id": "title_text",
                        "component": "Text",
                        "text": "### Markdown Rendering"
                    },
                    {
                        "id": "markdown_content",
                        "component": "Text",
                        "text": "# Heading 1\n\nThis is **bold** text and *italic* text.\n\n- List item 1\n- List item 2\n\n[Link to Google](https://google.com)"
                    }
                ]
            }
        }
    ]
}
