{
  "name": "@a2ui/lit",
  "version": "0.10.1",
  "description": "A2UI Lit Library",
  "author": "Google",
  "license": "Apache-2.0",
  "homepage": "https://a2ui.org/",
  "repository": {
    "directory": "renderers/lit",
    "type": "git",
    "url": "git+https://github.com/a2ui-project/a2ui.git"
  },
  "bugs": {
    "url": "https://github.com/a2ui-project/a2ui/issues"
  },
  "keywords": [
    "a2ui",
    "lit",
    "ai",
    "agent",
    "ui",
    "renderer"
  ],
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./0.8": {
      "types": "./src/0.8/core.d.ts",
      "default": "./src/0.8/core.js"
    },
    "./v0_8": {
      "types": "./src/0.8/core.d.ts",
      "default": "./src/0.8/core.js"
    },
    "./v0_9": {
      "types": "./src/v0_9/index.d.ts",
      "default": "./src/v0_9/index.js"
    },
    "./ui": {
      "types": "./src/0.8/ui/ui.d.ts",
      "default": "./src/0.8/ui/ui.js"
    }
  },
  "type": "module",
  "peerDependencies": {
    "@a2ui/markdown-it": "*"
  },
  "peerDependenciesMeta": {
    "@a2ui/markdown-it": {
      "optional": true
    }
  },
  "dependencies": {
    "@a2ui/web_core": "^0.10.1",
    "@lit-labs/signals": "^0.3.0",
    "@lit/context": "^1.1.6",
    "lit": "^3.3.3",
    "signal-utils": "^0.21.1",
    "zod": "^3.25.76"
  }
}